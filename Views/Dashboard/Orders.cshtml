@model List<ABC_Retail.Models.OrderViewModel>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Order Monitoring";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">Create New Order</div>
            <div class="card-body">
                <form asp-action="CreateOrder" method="post" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Order ID</label>
                        <input type="text" name="OrderId" class="form-control" placeholder="e.g. ORD-5001" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Customer Name</label>
                        <input type="text" name="CustomerName" class="form-control" placeholder="Full Name" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Amount (ZAR)</label>
                        <input type="number" step="0.01" name="Amount" class="form-control" placeholder="0.00" required>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Process Order</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>Order History (Azure Table)</span>
        <span class="badge bg-primary">@Model.Count Orders</span>
    </div>
    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-basket fa-3x text-muted mb-3"></i>
                <p>No orders found. Create your first order above!</p>
            </div>
        }
        else
        {
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Date/Time</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>@order.OrderId</strong></td>
                            <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@order.CustomerName</td>
                            <td>@order.Amount.ToString("C")</td>
                            <td>
                                <span class="badge @(order.Status == "Success" ? "bg-success" : (order.Status == "Failed" ? "bg-danger" : "bg-warning"))">
                                    @order.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="OrderDetails" asp-route-id="@order.OrderId" class="btn btn-sm btn-light">View Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

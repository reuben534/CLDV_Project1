@model List<ABC_Retail.Models.QueueMessageViewModel>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Order Processing";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <h4 class="mb-0 text-muted">Manage Queue Messages</h4>
        <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#enqueueMessageModal">
            <i class="fas fa-paper-plane me-1"></i> Enqueue New Message
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><i class="fas fa-list-ul me-2 text-primary"></i>Pending Queue Messages</h5>
        <div class="d-flex align-items-center">
            <span class="badge bg-primary rounded-pill me-3">@Model.Count Messages</span>
            <button onclick="window.location.reload();" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-sync-alt me-1"></i> Refresh
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-4">Message ID</th>
                        <th>Enqueued Time</th>
                        <th>Payload Content</th>
                        <th class="text-center">Deq. Count</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var msg in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <code>@msg.MessageId.Substring(0, 8)...</code>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="icon-sm bg-soft-primary text-primary rounded me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            <i class="fas fa-clock"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@msg.EnqueuedTime.ToLongTimeString()</h6>
                                            <small class="text-muted">@msg.EnqueuedTime.ToShortDateString()</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 350px;" title="@msg.Payload">
                                        @msg.Payload
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(msg.RetryCount > 1 ? "bg-warning" : "bg-light text-dark") rounded-pill px-3">
                                        @msg.RetryCount
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <form asp-action="ProcessMessage" method="post" class="d-inline">
                                        <input type="hidden" name="messageId" value="@msg.MessageId" />
                                        <input type="hidden" name="popReceipt" value="@msg.PopReceipt" />
                                        <button type="submit" class="btn btn-sm btn-success shadow-sm px-3">
                                            <i class="fas fa-check me-1"></i> Process
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-5">
                                    <i class="fas fa-inbox fa-3x text-light mb-3"></i>
                                    <h6 class="text-muted">Queue is currently empty</h6>
                                    <p class="small text-muted mb-0">No pending orders or messages found in Azure Queue Storage.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Enqueue Message Modal -->
<div class="modal fade" id="enqueueMessageModal" tabindex="-1" aria-labelledby="enqueueMessageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="enqueueMessageModalLabel">
                    <i class="fas fa-paper-plane me-2"></i>Enqueue New Transaction
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SendMessage" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Order Reference / ID</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                            <input type="text" class="form-control" name="orderId" placeholder="e.g. ORD-1001" required>
                        </div>
                        <div class="form-text">Used to link this message to a specific order.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Message Payload (Instruction)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-comment-alt"></i></span>
                            <textarea class="form-control" rows="4" name="payload" placeholder="Describe the task or action to be performed..." required></textarea>
                        </div>
                    </div>
                    <div class="alert alert-info py-2 mb-0">
                        <small><i class="fas fa-info-circle me-1"></i> This message will be sent to the <code>order-processing</code> queue.</small>
                    </div>
                </div>
                <div class="modal-footer bg-light p-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="fas fa-plus-circle me-1"></i> Send to Azure
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    .table > :not(caption) > * > * { padding: 1.25rem 0.75rem; vertical-align: middle; }
    .card { border-radius: 0.75rem; overflow: hidden; }
</style>
